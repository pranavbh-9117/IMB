# ──────────────────────────────────────────────
# Institute Management & Quiz Platform
# Environment Variable Template
#
# Copy this file to .env and fill in real values.
# ──────────────────────────────────────────────

# Server
APP_PORT=
APP_ENV=

# Database
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=

# JWT
# JWT_ACCESS_EXPIRY and JWT_REFRESH_EXPIRY must be Go duration strings.
# Valid units: ns, us, ms, s, m, h  (e.g. "15m", "168h")
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Super Admin Seed
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
