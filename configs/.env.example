# ──────────────────────────────────────────────
# Institute Management & Quiz Platform
# Environment Variable Template
#
# Copy this file to .env and fill in real values.
# ──────────────────────────────────────────────

# Server
APP_PORT=
APP_ENV=

# Database
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSLMODE=

# Database Connection Pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=2m
# JWT
# JWT_ACCESS_EXPIRY and JWT_REFRESH_EXPIRY must be Go duration strings.
# Valid units: ns, us, ms, s, m, h  (e.g. "15m", "168h")
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Super Admin Seed
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=


# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=


SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-personal-email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=noreply@institute.com

# Redis Cache
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
ADMIN_DASHBOARD_CACHE_TTL=5m
